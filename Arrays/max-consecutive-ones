class Solution {
public:
    int findMaxConsecutiveOnes(vector<int>& nums) {
        int n= nums.size();
        
        int cons=0;int j=0;

        for (int i=0;i<n;i++){
            if (nums[i]!= 0){
                j++;
            }
            else {
            cons = max(cons, j);
             j=0;
        }
        }
        cons = max(cons, j);

        return cons;
    }
    
};